# SQLite for local development. Swap for a Postgres connection string in production,
# e.g. postgresql://user:password@host:5432/dbname
DATABASE_URL="file:./dev.db"

# Auth.js (NextAuth) session secret — generate with: openssl rand -base64 32
AUTH_SECRET=""

# Single admin user for the /admin dashboard.
# Generate ADMIN_PASSWORD_HASH with: node scripts/hash-password.mjs "your-password"
# The script's output already escapes "$" as "\$" — paste it as-is. Next.js
# expands $VAR references in .env files, so an unescaped bcrypt hash (which
# starts with $2b$10$...) gets silently corrupted on load.
ADMIN_EMAIL=""
ADMIN_PASSWORD_HASH=""

# Optional: base URL used for metadata/OG tags and the sitemap. Defaults to
# http://localhost:3000 in development.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Optional: wire up an email service for contact form notifications later
# (e.g. Resend). Leave unset to only persist messages to the database.
# RESEND_API_KEY=""
